// HRIS — Prisma schema
// Multi-tenant model: every tenant-scoped row carries `organizationId`.
// Tenant isolation is enforced in the application query layer (see src/lib/tenant.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts (for the CLI) and is
  // passed to PrismaClient via the pg driver adapter (see src/lib/prisma.ts).
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  SUPER_ADMIN // reserved for platform operators (cross-tenant)
  ORG_ADMIN // full control within one organization
  HR_MANAGER // manage employees, departments, users
  MANAGER // view/manage own team
  EMPLOYEE // self-service only
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  PENDING
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

// ---------------------------------------------------------------------------
// Tenant root
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("UTC")
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  employees   Employee[]
  departments Department[]
  auditLogs   AuditLog[]

  leaveTypes       LeaveType[]
  leaveBalances    LeaveBalance[]
  leaveRequests    LeaveRequest[]
  timeEntries      TimeEntry[]
  shifts           Shift[]
  shiftAssignments ShiftAssignment[]
  payrollRuns      PayrollRun[]
  payslips         Payslip[]
  benefitPlans       BenefitPlan[]
  benefitEnrollments BenefitEnrollment[]
  dependents         Dependent[]
  holidays           Holiday[]
}

// ---------------------------------------------------------------------------
// Auth / access
// ---------------------------------------------------------------------------

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email        String
  passwordHash String
  role         UserRole   @default(EMPLOYEE)
  status       UserStatus @default(ACTIVE)

  // Optional 1:1 link to an employee profile (drives self-service).
  employee   Employee? @relation("EmployeeUser", fields: [employeeId], references: [id])
  employeeId String?   @unique

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auditLogs             AuditLog[]
  reviewedLeaveRequests LeaveRequest[] @relation("LeaveReviewer")
  createdPayrollRuns    PayrollRun[]   @relation("PayrollCreator")

  @@unique([organizationId, email])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Organizational structure
// ---------------------------------------------------------------------------

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // Self-referential hierarchy (department tree).
  parentId String?
  parent   Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DeptHierarchy")

  // Department head (an employee).
  headId String?
  head   Employee? @relation("DeptHead", fields: [headId], references: [id])

  employees Employee[] @relation("DeptEmployees")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([parentId])
}

// ---------------------------------------------------------------------------
// Employee records
// ---------------------------------------------------------------------------

model Employee {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employeeNumber String
  firstName      String
  lastName       String
  email          String
  phone          String?
  dateOfBirth    DateTime?
  gender         String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?

  // Employment
  jobTitle        String?
  employmentType  EmploymentType @default(FULL_TIME)
  status          EmployeeStatus @default(ACTIVE)
  hireDate        DateTime?
  terminationDate DateTime?

  departmentId String?
  department   Department? @relation("DeptEmployees", fields: [departmentId], references: [id])

  // Reporting line (manager hierarchy / org chart).
  managerId String?
  manager   Employee?  @relation("EmpHierarchy", fields: [managerId], references: [id])
  reports   Employee[] @relation("EmpHierarchy")

  headedDepartments Department[] @relation("DeptHead")
  user              User?        @relation("EmployeeUser")

  // Time & attendance
  leaveBalances    LeaveBalance[]
  leaveRequests    LeaveRequest[]
  timeEntries      TimeEntry[]
  shiftAssignments ShiftAssignment[]

  // Emergency contact
  emergencyContactName  String?
  emergencyContactPhone String?

  // Government / statutory IDs (Philippines)
  sssNumber        String? // Social Security System
  philHealthNumber String? // PhilHealth
  tin              String? // Tax Identification Number (BIR)
  pagIbigNumber    String? // Pag-IBIG / HDMF MID

  // Compensation (basis for payroll)
  monthlySalary    Float @default(0)
  monthlyAllowance Float @default(0)

  payslips           Payslip[]
  benefitEnrollments BenefitEnrollment[]
  dependents         Dependent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, employeeNumber])
  @@index([organizationId])
  @@index([organizationId, departmentId])
  @@index([organizationId, managerId])
}

// ---------------------------------------------------------------------------
// Audit trail (compliance — a single source of truth for "who did what")
// ---------------------------------------------------------------------------

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action     String // e.g. "employee.create"
  entityType String // e.g. "Employee"
  entityId   String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
}

// ---------------------------------------------------------------------------
// Time & Attendance (Milestone 2)
// ---------------------------------------------------------------------------

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveType {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name                  String
  description           String?
  defaultAllocationDays Int     @default(0)
  paid                  Boolean @default(true)
  colorHex              String? // e.g. "#6366f1" for UI accents
  isActive              Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  balances LeaveBalance[]
  requests LeaveRequest[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model LeaveBalance {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  year          Int
  allocatedDays Float @default(0)
  usedDays      Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@index([organizationId])
}

model LeaveRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  startDate DateTime
  endDate   DateTime
  days      Float // working days requested
  halfDay   Boolean @default(false) // single-day half-day request
  reason    String?

  status       LeaveRequestStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?              @relation("LeaveReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([employeeId])
}

model TimeEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  clockIn  DateTime
  clockOut DateTime? // null while the entry is open
  note     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, employeeId])
  @@index([organizationId, clockIn])
}

model Shift {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  startTime String // "09:00"
  endTime   String // "17:00"
  colorHex  String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ShiftAssignment[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model ShiftAssignment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId    String
  shift      Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  date DateTime @db.Date
  note String?

  createdAt DateTime @default(now())

  @@unique([employeeId, date])
  @@index([organizationId, date])
}

// ---------------------------------------------------------------------------
// Payroll (Milestone 3)
// ---------------------------------------------------------------------------

enum PayFrequency {
  MONTHLY
  SEMI_MONTHLY
  DAILY
}

enum PayrollStatus {
  DRAFT
  FINALIZED
  PAID
}

model PayrollRun {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  label       String
  frequency   PayFrequency  @default(MONTHLY)
  periodStart DateTime      @db.Date
  periodEnd   DateTime      @db.Date
  payDate     DateTime      @db.Date
  status      PayrollStatus @default(DRAFT)

  createdById String?
  createdBy   User?   @relation("PayrollCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payslips Payslip[]

  @@index([organizationId, periodStart])
}

model Payslip {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Earnings
  basicPay      Float @default(0)
  allowance     Float @default(0)
  overtimeHours Float @default(0)
  overtimePay   Float @default(0)
  otherEarnings Float @default(0)
  grossPay      Float @default(0)

  // Attendance-derived
  daysWorked      Float @default(0)
  absentDays      Float @default(0)
  unpaidLeaveDays Float @default(0)

  // Deductions (employee share)
  sss              Float @default(0)
  philHealth       Float @default(0)
  pagIbig          Float @default(0)
  withholdingTax   Float @default(0)
  absenceDeduction Float @default(0)
  otherDeductions  Float @default(0)
  totalDeductions  Float @default(0)

  // Employer share (informational / reporting)
  sssEr        Float @default(0)
  philHealthEr Float @default(0)
  pagIbigEr    Float @default(0)

  netPay Float   @default(0)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([payrollRunId, employeeId])
  @@index([organizationId, employeeId])
}

// ---------------------------------------------------------------------------
// Benefits administration (Milestone 4)
// ---------------------------------------------------------------------------

enum BenefitType {
  HEALTH
  LIFE
  RETIREMENT
}

enum EnrollmentStatus {
  ACTIVE
  CANCELLED
}

enum DependentRelation {
  SPOUSE
  CHILD
  PARENT
  OTHER
}

model BenefitPlan {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type        BenefitType
  name        String
  provider    String?
  description String?

  coverageAmount       Float? // e.g. life sum assured / HMO max benefit limit
  employeeContribution Float  @default(0) // monthly, reference only
  employerContribution Float  @default(0) // monthly, reference only
  isActive             Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments BenefitEnrollment[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Dependent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String
  relation    DependentRelation
  dateOfBirth DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments BenefitEnrollment[] @relation("EnrollmentDependents")

  @@index([organizationId])
  @@index([employeeId])
}

model BenefitEnrollment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  planId     String
  plan       BenefitPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  cancelledAt DateTime?
  notes       String?

  coveredDependents Dependent[] @relation("EnrollmentDependents")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, planId])
  @@index([organizationId])
}

// Company holidays — excluded from leave working-day counts.
model Holiday {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name String
  date DateTime @db.Date

  createdAt DateTime @default(now())

  @@unique([organizationId, date])
  @@index([organizationId])
}
