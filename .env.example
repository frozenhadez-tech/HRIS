# Copy this file to .env and fill in the values.

# PostgreSQL connection string (Prisma 7 reads this via prisma.config.ts and
# the pg driver adapter). For a zero-install option use a free hosted Postgres
# such as Neon (https://neon.tech) or Supabase.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hris?schema=public"

# Secret used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"
